{
  "id": "report.gen",
  "name": "Report Generator",
  "description": "Generates professional PDF, Word (.docx), and Excel (.xlsx) reports from structured data. Reports are saved to the conversation work directory.",
  "category": "Productivity",
  "version": "1.0.0",
  "publisher": "MyLocalAssistant",
  "keyId": "bundled-plugins",
  "toolMode": "json",
  "minContextK": 8,
  "entry": {
    "command": "mla-plugin-reportgen.exe",
    "args": []
  },
  "files": [],
  "tools": [
    {
      "name": "report.pdf",
      "description": "Generate a PDF report with a title and sections. Each section has an optional heading and text content.",
      "argumentsSchemaJson": "{\"type\":\"object\",\"properties\":{\"title\":{\"type\":\"string\",\"description\":\"Report title\"},\"sections\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"heading\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"content\"]},\"description\":\"List of sections\"},\"filename\":{\"type\":\"string\",\"description\":\"Optional output filename\"}},\"required\":[\"title\",\"sections\"]}"
    },
    {
      "name": "report.word",
      "description": "Generate a Word (.docx) document with a title and sections.",
      "argumentsSchemaJson": "{\"type\":\"object\",\"properties\":{\"title\":{\"type\":\"string\"},\"sections\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"heading\":{\"type\":\"string\"},\"content\":{\"type\":\"string\"}},\"required\":[\"content\"]}},\"filename\":{\"type\":\"string\"}},\"required\":[\"title\",\"sections\"]}"
    },
    {
      "name": "report.excel",
      "description": "Generate an Excel (.xlsx) workbook with one or more sheets of tabular data.",
      "argumentsSchemaJson": "{\"type\":\"object\",\"properties\":{\"title\":{\"type\":\"string\"},\"sheets\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\",\"description\":\"Sheet name\"},\"headers\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"Column headers\"},\"rows\":{\"type\":\"array\",\"items\":{\"type\":\"array\",\"items\":{\"type\":\"string\"}},\"description\":\"Data rows\"}},\"required\":[\"name\",\"rows\"]}},\"filename\":{\"type\":\"string\"}},\"required\":[\"title\",\"sheets\"]}"
    }
  ]
}
